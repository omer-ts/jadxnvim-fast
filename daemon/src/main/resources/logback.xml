<configuration>
    <!--
      Route all jadx/library logging to stderr so the JSON-RPC stream on stdout stays clean.
      Override the level with -Dorg.slf4j... or by editing this file when debugging the daemon.
    -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      jadx logs a decompile WARN for nearly every non-trivial method; on a 400k-class APK that is
      millions of lines to stderr, which dominates export time. Suppress below ERROR. Set the env
      var JADXD_LOG=warn (or edit here) when you actually need jadx warnings.
    -->
    <root level="${JADXD_LOG:-OFF}">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
